[
    {
        "title": "@@ExcelImport.config@@",
        "properties": [
            {
                "name": "id",
                "label": "ID",
                "type": "textfield",
                "required": "True",
                "regex_validation": "^[a-zA-Z0-9_]+$",
                "validation_message": "@@ExcelImport.invalidId@@"
            },
            {
                "name": "label",
                "label": "@@ExcelImport.label@@",
                "type": "textfield"
            },
            {
                "name": "required",
                "label": "@@ExcelImport.required@@",
                "description": "@@ExcelImport.requiredDesc@@",
                "type": "checkbox",
                "value": "",
                "options": [
                    {
                        "value": "true",
                        "label": ""
                    }
                ]
            },
            {
                "name": "columns",
                "label": "@@ExcelImport.columns@@",
                "description": "@@ExcelImport.columnsDesc@@",
                "type": "custom",
                "script_url": "[CONTEXT_PATH]/plugin/org.joget.plugin.melkart.ExcelImport/js/excel-import-columns.js",
                "columns": [
                    {
                        "key": "excelHeader",
                        "label": "@@ExcelImport.col.excelHeader@@",
                        "type": "textfield",
                        "required": "true"
                    },
                    {
                        "key": "fieldId",
                        "label": "@@ExcelImport.col.fieldId@@",
                        "type": "textfield"
                    },
                    {
                        "key": "required",
                        "label": "@@ExcelImport.col.required@@",
                        "type": "checkbox"
                    },
                    {
                        "key": "uniqueKey",
                        "label": "@@ExcelImport.col.uniqueKey@@",
                        "type": "checkbox"
                    },
                    {
                        "key": "type",
                        "label": "@@ExcelImport.col.type@@",
                        "type": "select",
                        "popup": "true",
                        "options": [
                            { "value": "", "label": "@@ExcelImport.col.type.text@@" },
                            { "value": "number", "label": "@@ExcelImport.col.type.number@@" },
                            { "value": "date", "label": "@@ExcelImport.col.type.date@@" },
                            { "value": "boolean", "label": "@@ExcelImport.col.type.boolean@@" }
                        ]
                    },
                    {
                        "key": "dateFormat",
                        "label": "@@ExcelImport.col.dateFormat@@",
                        "type": "textfield",
                        "popup": "true",
                        "control_field": "type",
                        "control_value": "date"
                    },
                    {
                        "key": "defaultValue",
                        "label": "@@ExcelImport.col.defaultValue@@",
                        "type": "textfield",
                        "popup": "true"
                    },
                    {
                        "key": "hideInPreview",
                        "label": "@@ExcelImport.col.hideInPreview@@",
                        "type": "checkbox"
                    }
                ],
                "labels": {
                    "options": "@@ExcelImport.col.options@@",
                    "optionsTitle": "@@ExcelImport.col.optionsTitle@@",
                    "addRow": "@@ExcelImport.col.addRow@@",
                    "done": "@@ExcelImport.col.done@@",
                    "moveUp": "@@ExcelImport.col.moveUp@@",
                    "moveDown": "@@ExcelImport.col.moveDown@@",
                    "delete": "@@ExcelImport.col.delete@@",
                    "noRows": "@@ExcelImport.col.noRows@@"
                }
            },
            {
                "name": "caseSensitiveHeaders",
                "label": "@@ExcelImport.caseSensitiveHeaders@@",
                "description": "@@ExcelImport.caseSensitiveHeadersDesc@@",
                "type": "checkbox",
                "value": "",
                "options": [
                    {
                        "value": "true",
                        "label": ""
                    }
                ]
            },
            {
                "name": "csvDelimiter",
                "label": "@@ExcelImport.csvDelimiter@@",
                "description": "@@ExcelImport.csvDelimiterDesc@@",
                "type": "textfield"
            },
            {
                "name": "csvQuote",
                "label": "@@ExcelImport.csvQuote@@",
                "description": "@@ExcelImport.csvQuoteDesc@@",
                "type": "textfield"
            }
        ]
    },
